# Chota Packet Backend — Environment Variables Template
# Copy this file to .env and fill in values.
# The backend works fully in mock mode with all defaults below.

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=8000
# HOST=0.0.0.0

# ─── Model paths (optional overrides) ────────────────────────────────────────
# MT5_MODEL_DIR=backend/models/mt5_lora_merged
# WHISPER_MODEL_ID=openai/whisper-tiny

# ─── HuggingFace cache (where base models are downloaded) ─────────────────────
# TRANSFORMERS_CACHE=~/.cache/huggingface
# HF_HOME=~/.cache/huggingface

# ─── OpenRouter (optional — only needed if testing cloud mode) ────────────────
# Leave empty for local-only mode. The user enters their key via the UI (FR-41).
# OPENROUTER_API_KEY=sk-or-v1-...

# ─── Logging level ────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
